generator client {
  provider = "prisma-client"
  output   = "../generated"
}

datasource db {
  provider = "sqlite"
}

model Candidate {
  id            String          @id @default(cuid())
  name          String
  email         String          @unique
  resumePath    String
  status        CandidateStatus @default(APPLIED)
  scoreQ1       Float?
  scoreQ2       Float?
  scoreTotal    Float?
  appliedAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model User {
  id       String @id @default(cuid())
  email    String @unique
  password String
  role     String @default("RECRUITER")
}

enum CandidateStatus {
  APPLIED
  PENDING_Q1
  PENDING_Q2
  SCORED
  PRIORITY_QUEUE
  REJECTED
  HUMAN_REVIEWED
}
